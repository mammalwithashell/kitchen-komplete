<!DOCTYPE html>
<html>
<head>
	<link rel="stylesheet" href="styles.css">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>

<ul>
  <form method= "get" action="/">
	<button class="button buttonhome">Home</button>
  </form>
  <form method= "get" action="/login">
	<button class="button button1">Login</button>
  </form>
  <form method= "get" action="/register">
	<button class="button button1">Register</button>
  </form>
  <form method= "get" action="about.html">
	<button class="button button1">About</button>
  </form>
  <form method= "get" action="/">
	<button class="button button1">Browse Recipes</button>
  </form>
</ul>

<!-- main section starts here -->

<div class="content">
    <div class="content-inside">
      <!-- <h1> "This is the landing page/home page without a user logged in (index.html)"</h1> -->
      <h1 style="text-align: center">Kitchen Komplete</h1>

      <div class="ex1">
        {{range .Rec}}
          {{.Name}} {{.Class}} {{.Ingredients}}<br></br>
        {{end}}
      </div>
    </div>
</div>

<!-- main section ends here -->
<footer class="footer"><p>Kitchen Komplete © 2020</p></footer>
</body>
</html>